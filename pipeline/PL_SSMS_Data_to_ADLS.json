{
	"name": "PL_PersonSqlservrToADLS",
	"properties": {
		"description": "Person Data from SSMS move  to ADLS Storage",
		"activities": [
			{
				"name": "PersonDataFromSSMSToADLS",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlServerSource",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobStorageWriteSettings",
							"copyBehavior": "FlattenHierarchy"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "PERSON_ID",
									"type": "Int32",
									"physicalType": "int"
								},
								"sink": {
									"name": "PERSON_ID",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "FIRST_NAME",
									"type": "String",
									"physicalType": "varchar"
								},
								"sink": {
									"name": "FIRST_NAME",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "LAST_NAME",
									"type": "String",
									"physicalType": "varchar"
								},
								"sink": {
									"name": "LAST_NAME",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "AGE",
									"type": "Int32",
									"physicalType": "int"
								},
								"sink": {
									"name": "AGE",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "JOB",
									"type": "String",
									"physicalType": "varchar"
								},
								"sink": {
									"name": "JOB",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "HIREDATE",
									"type": "Date",
									"physicalType": "date"
								},
								"sink": {
									"name": "HIREDATE",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "SALARY",
									"type": "Decimal",
									"physicalType": "decimal",
									"scale": 2,
									"precision": 7
								},
								"sink": {
									"name": "SALARY",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "LOCATION_ID",
									"type": "Int32",
									"physicalType": "int"
								},
								"sink": {
									"name": "LOCATION_ID",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "CLIENT_ID",
									"type": "Int32",
									"physicalType": "int"
								},
								"sink": {
									"name": "CLIENT_ID",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "ACTIVE_FLAG",
									"type": "String",
									"physicalType": "varchar"
								},
								"sink": {
									"name": "ACTIVE_FLAG",
									"type": "String",
									"physicalType": "String"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "Person",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "PersonADLS",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": []
	}
}