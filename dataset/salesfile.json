{
	"name": "salesfile",
	"properties": {
		"linkedServiceName": {
			"referenceName": "AzureBlobStoragefor SSMS",
			"type": "LinkedServiceReference"
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobStorageLocation",
				"fileName": {
					"value": "@concat('sale_', formatDateTime(utcNow(), 'yyyyMMdd'), '.csv')\n",
					"type": "Expression"
				},
				"container": "ssms-data"
			},
			"columnDelimiter": "|",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": []
	}
}